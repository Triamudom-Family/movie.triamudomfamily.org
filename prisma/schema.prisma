generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["movie"]
}

enum SeatStatus {
  AVAILABLE
  BOOKED
  BLOCKED
  BROKEN

  @@schema("movie")
}

enum Role {
  STAFF
  ADMIN
  STUDENT

  @@schema("movie")
}

model Event {
  id        String       @id @default(uuid())
  year      Int          @unique
  title     String
  venue     String?
  showAt    DateTime?
  createdAt DateTime     @default(now())
  students  Student[]
  seats     Seat[]
  bookings  BookingLog[]

  @@schema("movie")
}

model User {
  id              String    @id @default(uuid())
  name            String
  username        String?   @unique
  displayUsername String?
  email           String    @unique
  emailVerified   Boolean   @default(false)
  image           String?
  role            Role      @default(STAFF)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  sessions        Session[]
  accounts        Account[]
  students        Student[]

  @@schema("movie")
}

model Student {
  id         String   @id @default(uuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  googleId   String
  email      String
  name       String
  surname    String
  class      String
  rollNumber Int
  studentId  String
  qrToken    String
  seatId     String?
  seat       Seat?    @relation(fields: [eventId, seatId], references: [eventId, id])
  createdAt  DateTime @default(now())

  @@unique([eventId, userId])
  @@unique([eventId, googleId])
  @@unique([eventId, email])
  @@unique([eventId, studentId])
  @@unique([eventId, qrToken])
  @@unique([eventId, seatId])
  @@index([eventId])
  @@schema("movie")
}

model Seat {
  id        String
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  row       String
  number    Int
  section   String
  type      String
  status    SeatStatus @default(AVAILABLE)
  note      String?
  student   Student?
  bookedBy  String?
  bookedAt  DateTime?
  updatedAt DateTime   @updatedAt

  @@id([eventId, id])
  @@unique([eventId, row, number])
  @@index([eventId])
  @@index([row])
  @@index([status])
  @@schema("movie")
}

model BookingLog {
  id          String   @id @default(uuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  seatId      String
  studentId   String?
  action      String
  performedBy String
  performedAt DateTime @default(now())
  note        String?

  @@index([eventId])
  @@index([performedAt])
  @@index([seatId])
  @@index([performedBy])
  @@schema("movie")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@schema("movie")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@schema("movie")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@schema("movie")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@schema("movie")
}
